{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/edithatogo/corpus-nz-hansard/schemas/release_evidence_ledger.schema.json",
  "title": "Release Evidence Ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ledger_version",
    "generated_at",
    "repository",
    "commit_sha",
    "workflow",
    "dataset",
    "huggingface",
    "zenodo",
    "manifests",
    "artifacts",
    "provenance_policy"
  ],
  "properties": {
    "ledger_version": {
      "type": "integer",
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "commit_sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$|^unknown$"
    },
    "workflow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "run_id", "run_url"],
      "properties": {
        "name": {
          "type": ["string", "null"]
        },
        "run_id": {
          "type": ["string", "null"]
        },
        "run_url": {
          "type": ["string", "null"]
        }
      }
    },
    "dataset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "record_count", "coverage_statement"],
      "properties": {
        "schema_version": {
          "type": "string",
          "minLength": 1
        },
        "record_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "coverage_statement": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "huggingface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo_id", "revision"],
      "properties": {
        "repo_id": {
          "type": ["string", "null"]
        },
        "revision": {
          "type": ["string", "null"]
        }
      }
    },
    "zenodo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["doi", "concept_doi"],
      "properties": {
        "doi": {
          "type": ["string", "null"]
        },
        "concept_doi": {
          "type": ["string", "null"]
        }
      }
    },
    "manifests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileEvidence"
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/fileEvidence"
      }
    },
    "provenance_policy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_class",
          "strategy",
          "status",
          "evidence"
        ],
        "properties": {
          "artifact_class": {
            "type": "string",
            "minLength": 1
          },
          "strategy": {
            "enum": [
              "github_artifact_attestation",
              "slsa_style_provenance",
              "signed_checksum",
              "revision_and_manifest_hash",
              "documented_deferral"
            ]
          },
          "status": {
            "enum": ["enforced", "documented", "deferred"]
          },
          "evidence": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "fileEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "bytes", "sha256"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    }
  }
}
