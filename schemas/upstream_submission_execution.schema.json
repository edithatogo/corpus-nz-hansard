{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "track_id",
    "repository",
    "generated_at",
    "release_ladder",
    "submission_state",
    "submission_targets",
    "submission_templates",
    "evidence_sources",
    "known_exclusions",
    "validation_results"
  ],
  "properties": {
    "manifest_version": {
      "const": 1
    },
    "track_id": {
      "const": "upstream_submission_execution_20260610"
    },
    "repository": {
      "const": "corpus-nz-hansard"
    },
    "generated_at": {
      "type": "string"
    },
    "release_ladder": {
      "type": "string"
    },
    "submission_state": {
      "enum": [
        "not-submitted",
        "submitted",
        "accepted",
        "rejected",
        "waiting",
        "blocked"
      ]
    },
    "submission_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "mechanism",
          "local_artifacts",
          "prerequisite_track",
          "submission_status",
          "blocker_reason",
          "submission_url",
          "submitted_at"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "mechanism": {
            "type": "string"
          },
          "local_artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "prerequisite_track": {
            "type": "string"
          },
          "submission_status": {
            "enum": [
              "not-submitted",
              "blocked",
              "submitted",
              "accepted",
              "rejected",
              "waiting"
            ]
          },
          "blocker_reason": {
            "type": "string"
          },
          "submission_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "submitted_at": {
            "type": [
              "string",
              "null"
            ]
          },
          "response_status": {
            "type": [
              "string",
              "null"
            ]
          },
          "follow_up_track": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "submission_templates": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target",
          "template_type",
          "template_location",
          "review_gate"
        ],
        "properties": {
          "target": {
            "type": "string"
          },
          "template_type": {
            "type": "string"
          },
          "template_location": {
            "type": "string"
          },
          "review_gate": {
            "type": "string"
          }
        }
      }
    },
    "evidence_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "known_exclusions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "validation_results": {
      "type": "object",
      "required": [
        "targets_catalogued",
        "external_submission_links_recorded",
        "blocked_targets",
        "readiness_boundary"
      ],
      "properties": {
        "targets_catalogued": {
          "type": "boolean"
        },
        "external_submission_links_recorded": {
          "type": "boolean"
        },
        "blocked_targets": {
          "type": "integer",
          "minimum": 0
        },
        "readiness_boundary": {
          "enum": [
            "local-review-only",
            "submitted",
            "accepted",
            "rejected",
            "waiting"
          ]
        }
      }
    }
  }
}
