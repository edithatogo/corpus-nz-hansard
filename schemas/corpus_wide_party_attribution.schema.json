{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/corpus-wide-party-attribution.schema.json",
  "title": "Corpus-Wide Party Attribution Row",
  "type": "object",
  "required": [
    "source_stable_id",
    "source_file",
    "source_row_number",
    "parliament_number",
    "parliament_document_id",
    "document_type",
    "document_content_date",
    "party_vote_side",
    "party_label_raw",
    "party_label_normalized",
    "party_id",
    "party_attribution_source",
    "party_attribution_method",
    "party_attribution_confidence",
    "party_attribution_status",
    "member_identity_status",
    "review_status",
    "release_status",
    "source_hash",
    "authority_snapshot_hash"
  ],
  "properties": {
    "source_stable_id": {"type": "string", "minLength": 1},
    "source_file": {"type": "string", "minLength": 1},
    "source_row_number": {"type": "integer", "minimum": 1},
    "parliament_number": {"type": "integer"},
    "parliament_document_id": {"type": "string"},
    "document_type": {"type": "string"},
    "document_content_date": {"type": ["string", "null"]},
    "party_vote_side": {"type": "string"},
    "party_label_raw": {"type": "string"},
    "party_label_normalized": {"type": "string"},
    "party_vote_count": {"type": ["integer", "null"]},
    "party_id": {"type": "string"},
    "party_attribution_source": {"type": "string"},
    "party_attribution_url": {"type": "string"},
    "party_attribution_method": {"type": "string"},
    "party_attribution_confidence": {"enum": ["high", "medium", "low", "none"]},
    "party_attribution_status": {
      "enum": ["authoritative", "alias", "ambiguous", "unresolved", "blocked"]
    },
    "member_id": {"type": "string"},
    "member_display_name": {"type": "string"},
    "member_identity_status": {"type": "string"},
    "dependency_state": {"type": "string"},
    "review_status": {"enum": ["unreviewed", "reviewed", "needs-review"]},
    "release_status": {"type": "string"},
    "source_hash": {"type": "string", "minLength": 1},
    "authority_snapshot_hash": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
