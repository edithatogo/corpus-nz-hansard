{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danielmordaunt/corpus-nz-hansard/schemas/nz_parliamentary_procedure_model.schema.json",
  "title": "NZ Parliamentary Procedure Model",
  "type": "object",
  "required": [
    "manifest_version",
    "repository",
    "generated_at",
    "authority_source_ids",
    "procedural_categories",
    "component_links",
    "uncertainty_policy",
    "validation_requirements",
    "endpoint_mappings",
    "publication_guardrails"
  ],
  "additionalProperties": false,
  "properties": {
    "manifest_version": {
      "type": "integer",
      "const": 1
    },
    "repository": {
      "type": "string",
      "const": "corpus-nz-hansard"
    },
    "generated_at": {
      "type": "string",
      "format": "date"
    },
    "authority_source_ids": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "procedural_categories": {
      "type": "array",
      "minItems": 8,
      "items": {
        "$ref": "#/$defs/procedural_category"
      },
      "uniqueItems": true
    },
    "component_links": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "uncertainty_policy": {
      "type": "object",
      "required": [
        "status_values",
        "rule"
      ],
      "additionalProperties": false,
      "properties": {
        "status_values": {
          "type": "array",
          "minItems": 4,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "rule": {
          "type": "string"
        }
      }
    },
    "validation_requirements": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "endpoint_mappings": {
      "type": "array",
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/endpoint_mapping"
      },
      "uniqueItems": true
    },
    "publication_guardrails": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "procedural_category": {
      "type": "object",
      "required": [
        "category",
        "description",
        "document_types",
        "required_links",
        "authority_source_ids",
        "uncertainty_fields",
        "not_speech_turn_by_default"
      ],
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "document_types": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "required_links": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "authority_source_ids": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "uncertainty_fields": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "not_speech_turn_by_default": {
          "type": "boolean"
        }
      }
    },
    "endpoint_mapping": {
      "type": "object",
      "required": [
        "endpoint",
        "track_id",
        "mapped_categories",
        "mapping_note",
        "required_validation"
      ],
      "additionalProperties": false,
      "properties": {
        "endpoint": {
          "type": "string"
        },
        "track_id": {
          "type": "string"
        },
        "mapped_categories": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "mapping_note": {
          "type": "string"
        },
        "required_validation": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
