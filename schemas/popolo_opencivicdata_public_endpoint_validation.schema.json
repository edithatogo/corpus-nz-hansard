{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danielmordaunt/corpus-nz-hansard/schemas/popolo_opencivicdata_public_endpoint_validation.schema.json",
  "title": "Popolo Open Civic Data Public Endpoint Validation Manifest",
  "type": "object",
  "required": [
    "endpoint",
    "artifact_name",
    "artifact_version",
    "release_series_id",
    "release_level",
    "release_status",
    "publication_target",
    "validation_manifest",
    "input_release_versions",
    "known_exclusions",
    "dependency_groups",
    "dependency_validation",
    "validation_command",
    "output_artifacts",
    "validation_results",
    "traceability",
    "manifest_sha256"
  ],
  "additionalProperties": true,
  "properties": {
    "endpoint": { "type": "string" },
    "endpoint_track": { "type": "string" },
    "release_series_id": { "type": "string" },
    "release_level": { "type": "string" },
    "artifact_name": { "type": "string" },
    "artifact_version": { "type": "string" },
    "release_status": { "type": "string" },
    "publication_target": { "type": "string" },
    "upstream_contribution_target": { "type": "string" },
    "validation_manifest": { "type": "string" },
    "input_release_versions": { "type": "object" },
    "known_exclusions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependency_groups": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependency_validation": { "type": "object" },
    "validation_command": { "type": "string" },
    "output_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation_results": { "type": "object" },
    "traceability": {
      "type": "array",
      "items": { "type": "object" }
    },
    "manifest_sha256": { "type": "string" }
  }
}
