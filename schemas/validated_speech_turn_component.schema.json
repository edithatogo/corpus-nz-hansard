{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/validated-speech-turn-component.schema.json",
  "title": "Validated Speech Turn Component Row",
  "type": "object",
  "required": [
    "turn_id",
    "source_stable_id",
    "source_file",
    "source_row_number",
    "parliament_document_id",
    "parliament_number",
    "document_type",
    "title",
    "turn_index",
    "speaker_candidate",
    "speaker_member_id",
    "speaker_identity_status",
    "speaker_resolution_confidence",
    "speech_text",
    "source_selector",
    "confidence",
    "method",
    "review_status",
    "release_status",
    "source_hash",
    "validation_hash"
  ],
  "properties": {
    "turn_id": {"type": "string", "minLength": 1},
    "source_stable_id": {"type": "string", "minLength": 1},
    "source_file": {"type": "string", "minLength": 1},
    "source_row_number": {"type": "integer", "minimum": 1},
    "parliament_document_id": {"type": "string", "minLength": 1},
    "parliament_number": {"type": "integer"},
    "document_type": {"type": "string", "minLength": 1},
    "title": {"type": "string", "minLength": 1},
    "turn_index": {"type": "integer", "minimum": 1},
    "speaker_candidate": {"type": "string", "minLength": 1},
    "speaker_member_id": {"type": "string"},
    "speaker_identity_status": {
      "enum": ["validated", "blocked-pending-validated-member-identity", "unresolved", "ambiguous", "excluded"]
    },
    "speaker_resolution_confidence": {"enum": ["high", "medium", "low", "none"]},
    "speech_text": {"type": "string", "minLength": 1},
    "source_selector": {"type": "string", "minLength": 1},
    "confidence": {"enum": ["high", "medium", "low"]},
    "method": {"type": "string", "minLength": 1},
    "review_status": {"enum": ["unreviewed", "reviewed", "needs-review"]},
    "release_status": {"enum": ["validated-component", "blocked-pending-validation"]},
    "source_hash": {"type": "string", "minLength": 1},
    "validation_hash": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
