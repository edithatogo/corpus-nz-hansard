{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "fixture_version": {
      "const": 1
    },
    "repository": {
      "const": "corpus-nz-hansard"
    },
    "reviewed_at": {
      "format": "date",
      "type": "string"
    },
    "samples": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "sample_id": {
            "pattern": "^gold-[a-z-]+-[0-9]{2}$",
            "type": "string"
          },
          "domain": {
            "enum": [
              "member_resolution",
              "party_attribution",
              "speech_turn",
              "vote",
              "topic_coding"
            ]
          },
          "example_class": {
            "enum": [
              "positive",
              "negative",
              "ambiguous",
              "unresolved",
              "excluded"
            ]
          },
          "target_component_type": {
            "type": "string"
          },
          "target_component_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "source_reference": {
            "additionalProperties": false,
            "properties": {
              "release_version": {
                "const": "0.1.0"
              },
              "parliament_number": {
                "minimum": 47,
                "type": "integer"
              },
              "document_type": {
                "type": "string"
              },
              "source_file": {
                "type": "string"
              },
              "source_row_number": {
                "minimum": 1,
                "type": [
                  "integer",
                  "null"
                ]
              },
              "parliament_document_id": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "release_version",
              "parliament_number",
              "document_type",
              "source_file",
              "source_row_number",
              "parliament_document_id"
            ],
            "type": "object"
          },
          "text_excerpt": {
            "minLength": 1,
            "type": "string"
          },
          "label": {
            "additionalProperties": false,
            "properties": {
              "status": {
                "enum": [
                  "gold_positive",
                  "gold_negative",
                  "gold_ambiguous",
                  "gold_unresolved",
                  "gold_excluded"
                ]
              },
              "value": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "expected_behavior": {
                "minLength": 1,
                "type": "string"
              },
              "label_provenance": {
                "items": {
                  "type": "string"
                },
                "minItems": 1,
                "type": "array",
                "uniqueItems": true
              }
            },
            "required": [
              "status",
              "value",
              "expected_behavior",
              "label_provenance"
            ],
            "type": "object"
          },
          "sampling_frame": {
            "minLength": 1,
            "type": "string"
          },
          "review": {
            "additionalProperties": false,
            "properties": {
              "review_status": {
                "const": "reviewed"
              },
              "reviewer": {
                "minLength": 1,
                "type": "string"
              },
              "reviewed_at": {
                "format": "date",
                "type": "string"
              },
              "review_method": {
                "minLength": 1,
                "type": "string"
              },
              "model_generated_label": {
                "const": false
              }
            },
            "required": [
              "review_status",
              "reviewer",
              "reviewed_at",
              "review_method",
              "model_generated_label"
            ],
            "type": "object"
          }
        },
        "required": [
          "sample_id",
          "domain",
          "example_class",
          "target_component_type",
          "target_component_id",
          "source_reference",
          "text_excerpt",
          "label",
          "sampling_frame",
          "review"
        ],
        "type": "object"
      },
      "minItems": 25,
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "fixture_version",
    "repository",
    "reviewed_at",
    "samples"
  ],
  "type": "object"
}
