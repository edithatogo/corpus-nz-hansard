{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/corpus-wide-member-identity.schema.json",
  "title": "Corpus-Wide Member Identity Row",
  "type": "object",
  "required": [
    "source_stable_id",
    "source_file",
    "source_row_number",
    "parliament_number",
    "parliament_document_id",
    "document_type",
    "document_content_date",
    "member_of_parliament_raw",
    "member_raw_token",
    "member_token_index",
    "member_token_count",
    "multi_member_field",
    "member_id",
    "member_display_name",
    "member_authority_source",
    "member_authority_url",
    "member_resolution_method",
    "member_resolution_confidence",
    "member_resolution_status",
    "review_status",
    "release_status",
    "source_hash",
    "authority_snapshot_hash"
  ],
  "properties": {
    "source_stable_id": {"type": "string", "minLength": 1},
    "source_file": {"type": "string", "minLength": 1},
    "source_row_number": {"type": "integer", "minimum": 1},
    "parliament_number": {"type": "integer"},
    "parliament_document_id": {"type": "string"},
    "document_type": {"type": "string"},
    "document_content_date": {"type": ["string", "null"]},
    "member_of_parliament_raw": {"type": "string"},
    "member_raw_token": {"type": "string"},
    "member_token_index": {"type": "integer", "minimum": 1},
    "member_token_count": {"type": "integer", "minimum": 1},
    "multi_member_field": {"type": "boolean"},
    "member_id": {"type": "string"},
    "member_display_name": {"type": "string"},
    "member_authority_source": {"type": "string"},
    "member_authority_url": {"type": "string"},
    "member_resolution_method": {"type": "string"},
    "member_resolution_confidence": {"enum": ["high", "medium", "low", "none"]},
    "member_resolution_status": {
      "enum": ["exact", "alias", "multi-person", "unresolved", "ambiguous", "conflict"]
    },
    "review_status": {"enum": ["unreviewed", "reviewed", "needs-review"]},
    "release_status": {"enum": ["blocked-pending-validation", "validated-component"]},
    "source_hash": {"type": "string", "minLength": 1},
    "authority_snapshot_hash": {"type": "string", "minLength": 1},
    "notes": {"type": "string"}
  },
  "additionalProperties": false
}
