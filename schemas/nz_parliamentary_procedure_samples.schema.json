{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/danielmordaunt/corpus-nz-hansard/schemas/nz_parliamentary_procedure_samples.schema.json",
  "title": "NZ Parliamentary Procedure Samples",
  "type": "object",
  "required": [
    "fixture_version",
    "repository",
    "reviewed_at",
    "samples"
  ],
  "additionalProperties": false,
  "properties": {
    "fixture_version": {
      "type": "integer",
      "const": 1
    },
    "repository": {
      "type": "string",
      "const": "corpus-nz-hansard"
    },
    "reviewed_at": {
      "type": "string",
      "format": "date"
    },
    "samples": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "required": [
          "sample_id",
          "category",
          "document_type",
          "source_reference",
          "text_excerpt",
          "expected_component",
          "authority_source_ids",
          "uncertainty_status",
          "review"
        ],
        "additionalProperties": false,
        "properties": {
          "sample_id": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "document_type": {
            "type": "string"
          },
          "source_reference": {
            "type": "object"
          },
          "text_excerpt": {
            "type": "string"
          },
          "expected_component": {
            "type": "object"
          },
          "authority_source_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "uncertainty_status": {
            "type": "string"
          },
          "review": {
            "type": "object",
            "required": [
              "review_status",
              "reviewer",
              "reviewed_at",
              "model_generated_label"
            ],
            "additionalProperties": true,
            "properties": {
              "review_status": {
                "type": "string",
                "const": "reviewed"
              },
              "reviewer": {
                "type": "string"
              },
              "reviewed_at": {
                "type": "string",
                "format": "date"
              },
              "model_generated_label": {
                "type": "boolean",
                "const": false
              }
            }
          }
        }
      }
    }
  }
}
